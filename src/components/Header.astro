---
import { nav, site } from '../lib/site';

const currentPath = Astro.url.pathname;
function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header id="site-header" class="sticky top-0 z-50 border-b border-sand-200/60 bg-cream-100/85 backdrop-blur-md transition-shadow">
  <div class="container-page flex h-[72px] items-center justify-between">
    <a href="/" class="group flex flex-col leading-none">
      <span class="name-warm text-xl text-ink-900 group-hover:text-sage-700 transition-colors">
        {site.shortName}
      </span>
      <span class="eyebrow !text-[11px] !tracking-[0.18em] text-sage-600">Psikolojik Danışman</span>
    </a>

    <nav aria-label="Ana menü" class="hidden md:flex items-center gap-7">
      {nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            'font-body text-[15px] transition-colors hover:text-sage-700',
            isActive(item.href) ? 'text-sage-700 font-semibold' : 'text-ink-700',
          ]}
          aria-current={isActive(item.href) ? 'page' : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="hidden md:block">
      <a href="/iletisim/" class="btn-primary !px-5 !py-3 text-[14px]">Görüşme Talep Et</a>
    </div>

    <button
      id="menu-toggle"
      type="button"
      class="md:hidden inline-flex h-11 w-11 items-center justify-center rounded-full border border-sand-300 text-ink-900 cursor-pointer"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Menüyü aç"
    >
      <svg id="icon-open" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M4 7h16M4 12h16M4 17h16" />
      </svg>
      <svg id="icon-close" class="hidden h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M6 6l12 12M18 6L6 18" />
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden md:hidden border-t border-sand-200/60 bg-cream-100">
    <nav aria-label="Mobil menü" class="container-page flex flex-col gap-1 py-4">
      {nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            'rounded-xl px-3 py-3 font-body text-[15px] transition-colors',
            isActive(item.href) ? 'bg-sage-50 text-sage-700 font-semibold' : 'text-ink-700 hover:bg-sage-50',
          ]}
        >
          {item.label}
        </a>
      ))}
      <a href="/iletisim/" class="btn-primary mt-3 w-full">Görüşme Talep Et</a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    toggle.setAttribute('aria-label', expanded ? 'Menüyü aç' : 'Menüyü kapat');
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
  });

  const header = document.getElementById('site-header');
  const onScroll = () => {
    if (!header) return;
    header.classList.toggle('shadow-[0_8px_24px_-16px_rgba(58,54,44,0.4)]', window.scrollY > 8);
  };
  document.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
