---
import { whatsappLink } from '../lib/site';
---

<section class="relative flex h-screen min-h-[640px] w-full items-center justify-center overflow-hidden">
  <img
    src="/images/slider.jpeg"
    alt="Sakin, deniz manzaralı bir görüşme/çalışma odası"
    class="absolute inset-0 h-full w-full object-cover"
    fetchpriority="high"
    loading="eager"
    decoding="async"
  />
  <div
    class="absolute inset-0 bg-gradient-to-b from-ink-900/45 via-ink-900/35 to-ink-900/80"
    aria-hidden="true"
  >
  </div>
  <div
    class="absolute inset-0 bg-gradient-to-t from-sky-700/30 via-transparent to-transparent"
    aria-hidden="true"
  >
  </div>

  <div class="hero-fade-in container-page relative z-10 flex flex-col items-center px-6 text-center">
    <p class="font-display text-base italic tracking-[0.02em] text-cream-50/90 sm:text-lg">
      Online Psikolojik Danışman
    </p>
    <h1 class="mt-3 font-display text-[2.6rem] italic font-medium leading-[1.12] text-cream-50 sm:text-6xl md:text-[4.2rem]">
      Selcan Sarılmış
    </h1>
    <p class="mt-6 max-w-md text-[17px] leading-relaxed text-cream-50/85 sm:text-lg">
      Bulunduğunuz yerden, kendi hızınızda, online görüşmelerle yanınızdayım.
    </p>

    <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
      <a href="/iletisim/" class="btn-primary !bg-sky-600 hover:!bg-sky-700">
        Görüşme Talep Et
      </a>
      <a
        href={whatsappLink()}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-secondary !border-cream-50/50 !bg-transparent !text-cream-50 hover:!bg-cream-50/10 hover:!border-cream-50"
      >
        WhatsApp'tan Yazın
      </a>
    </div>
  </div>

  <a
    href="#main-content"
    class="absolute bottom-24 left-1/2 z-10 -translate-x-1/2 text-cream-50/80 transition-opacity hover:text-cream-50 sm:bottom-32 md:bottom-36"
    aria-label="Sayfada aşağı kaydır"
  >
    <svg class="h-6 w-6 animate-bounce motion-reduce:animate-none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
      <path d="M12 4v16M6 14l6 6 6-6" />
    </svg>
  </a>
</section>
