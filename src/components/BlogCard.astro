---
interface Props {
  href: string;
  title: string;
  excerpt: string;
  category: string;
  readingTime: string;
  pubDate: Date;
  image?: string;
  imageAlt?: string;
}
const { href, title, excerpt, category, readingTime, pubDate, image, imageAlt } = Astro.props;
const formatted = pubDate.toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' });
---

<a href={href} class="card-surface reveal group flex flex-col overflow-hidden transition-transform duration-300 hover:-translate-y-1 cursor-pointer">
  {image && (
    <div class="aspect-[16/9] w-full overflow-hidden bg-sage-50">
      <img
        src={image}
        alt={imageAlt ?? ''}
        loading="lazy"
        class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.03]"
      />
    </div>
  )}
  <div class="flex flex-col gap-3 p-7">
    <span class="eyebrow">{category}</span>
    <h3 class="font-display text-xl text-ink-900 group-hover:text-sage-700">{title}</h3>
    <p class="text-[15px] leading-relaxed text-ink-700">{excerpt}</p>
    <div class="mt-2 flex items-center gap-3 text-sm text-ink-700/70">
      <span>{formatted}</span>
      <span aria-hidden="true">·</span>
      <span>{readingTime} okuma</span>
    </div>
  </div>
</a>
