---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Accordion from '../../components/Accordion.astro';
import { whatsappLink } from '../../lib/site';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const areas = await getCollection('alanlar');
  return areas.map((area) => ({
    params: { slug: area.id },
    props: { area },
  }));
}

const { area } = Astro.props;
const { Content } = await render(area);
---

<BaseLayout title={area.data.title} description={area.data.summary}>
  <section class="bg-sage-50 py-16">
    <div class="container-page max-w-2xl">
      <a href="/danismanlik-alanlarim/" class="text-sm font-semibold text-sage-700">← Tüm Danışmanlık Alanları</a>
      <p class="eyebrow mt-4">Danışmanlık Alanı</p>
      <h1 class="mt-3 font-display text-4xl text-ink-900 sm:text-5xl">{area.data.title}</h1>
      <p class="mt-5 text-lg leading-relaxed text-ink-700">{area.data.summary}</p>
    </div>
  </section>

  <section class="container-page py-16">
    <div class="prose prose-lg max-w-2xl text-ink-700">
      <Content />
    </div>
  </section>

  <section class="bg-sage-50 py-16">
    <div class="container-page grid gap-12 md:grid-cols-2">
      <div>
        <p class="eyebrow">Kimler İçin</p>
        <ul class="mt-5 space-y-3">
          {area.data.forWho.map((item: string) => (
            <li class="flex gap-3 text-[16px] leading-relaxed text-ink-800">
              <svg class="mt-1 h-5 w-5 shrink-0 text-sage-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                <path d="M5 12l4 4L19 6" />
              </svg>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <p class="eyebrow">Süreç Nasıl İlerler</p>
        <ol class="mt-5 space-y-5">
          {area.data.process.map((item: string, i: number) => (
            <li class="flex gap-4">
              <span class="font-display text-2xl text-sky-600">{String(i + 1).padStart(2, '0')}</span>
              <span class="text-[16px] leading-relaxed text-ink-800">{item}</span>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  {area.data.faq?.length > 0 && (
    <section class="container-page py-16">
      <p class="eyebrow">Sık Sorulan Sorular</p>
      <div class="mt-6 max-w-2xl">
        <Accordion items={area.data.faq} idPrefix={area.id} />
      </div>
    </section>
  )}

  <section class="container-page py-16">
    <div class="card-surface flex flex-col items-center gap-5 px-8 py-12 text-center">
      <h2 class="font-display text-2xl text-ink-900 sm:text-3xl">Bu konuda görüşmek ister misiniz?</h2>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={whatsappLink()} target="_blank" rel="noopener noreferrer" class="btn-primary">WhatsApp'tan Yazın</a>
        <a href="/iletisim/" class="btn-secondary">İletişim Formu</a>
      </div>
    </div>
  </section>
</BaseLayout>
