---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Accordion from '../../components/Accordion.astro';
import { whatsappLink } from '../../lib/site';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const areas = await getCollection('alanlar');
  return areas.map((area) => ({
    params: { slug: area.id },
    props: { area },
  }));
}

const { area } = Astro.props;
const { Content } = await render(area);
---

<BaseLayout
  title={area.data.metaTitle ?? area.data.title}
  description={area.data.metaDescription ?? area.data.summary}
>
  <section class="bg-sage-50 py-16 md:py-20">
    <div
      class:list={[
        'container-page grid items-center gap-10',
        area.data.image ? 'md:grid-cols-[1.05fr_0.95fr]' : 'max-w-2xl',
      ]}
    >
      <div>
        <a href="/danismanlik-alanlarim/" class="text-sm font-semibold text-sage-700">← Tüm Danışmanlık Alanları</a>
        <p class="eyebrow mt-4">Danışmanlık Alanı</p>
        <h1 class="mt-3 font-display text-4xl text-ink-900 sm:text-5xl">{area.data.title}</h1>
        <p class="mt-5 text-lg leading-relaxed text-ink-700">{area.data.summary}</p>
        <div class="mt-7 flex flex-wrap gap-4">
          <a href={whatsappLink()} target="_blank" rel="noopener noreferrer" class="btn-primary">WhatsApp'tan Yazın</a>
          <a href="/iletisim/" class="btn-secondary">İletişim Formu</a>
        </div>
      </div>

      {area.data.image && (
        <div class="relative mx-auto aspect-[4/3] w-full max-w-md">
          <div class="absolute inset-0 translate-x-3 translate-y-3 rounded-2xl bg-sky-300/60"></div>
          <img
            src={area.data.image}
            alt={area.data.imageAlt ?? area.data.title}
            width="800"
            height="600"
            loading="eager"
            class="relative h-full w-full rounded-2xl border border-cream-50 object-cover"
          />
        </div>
      )}
    </div>
  </section>

  <section class="container-page py-16">
    <div class="prose prose-lg max-w-2xl text-ink-700">
      <Content />
    </div>
  </section>

  {area.data.whyOnline && area.data.whyOnline.length > 0 && (
    <section class="bg-sky-700 py-16 text-cream-50 md:py-20">
      <div class="container-page">
        <div class="max-w-xl">
          <p class="eyebrow text-sky-300">Neden Online Alınmalı?</p>
          <h2 class="mt-3 font-display text-3xl sm:text-4xl">
            Online {area.data.title.toLocaleLowerCase('tr-TR')} avantajları
          </h2>
        </div>
        <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {area.data.whyOnline.map((item: { title: string; text: string }) => (
            <div class="rounded-2xl border border-cream-50/15 bg-cream-50/5 p-6">
              <svg class="h-6 w-6 text-sky-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                <path d="M5 12l4 4L19 6" />
              </svg>
              <h3 class="mt-4 font-display text-lg text-cream-50">{item.title}</h3>
              <p class="mt-2 text-[15px] leading-relaxed text-cream-50/80">{item.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="bg-sage-50 py-16">
    <div class="container-page grid gap-12 md:grid-cols-2">
      <div>
        <p class="eyebrow">Kimler İçin</p>
        <ul class="mt-5 space-y-3">
          {area.data.forWho.map((item: string) => (
            <li class="flex gap-3 text-[16px] leading-relaxed text-ink-800">
              <svg class="mt-1 h-5 w-5 shrink-0 text-sage-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                <path d="M5 12l4 4L19 6" />
              </svg>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <p class="eyebrow">Süreç Nasıl İlerler</p>
        <ol class="mt-5 space-y-5">
          {area.data.process.map((item: string, i: number) => (
            <li class="flex gap-4">
              <span class="font-display text-2xl text-sky-600">{String(i + 1).padStart(2, '0')}</span>
              <span class="text-[16px] leading-relaxed text-ink-800">{item}</span>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  {area.data.faq?.length > 0 && (
    <section class="container-page py-16">
      <p class="eyebrow">Sık Sorulan Sorular</p>
      <div class="mt-6 max-w-2xl">
        <Accordion items={area.data.faq} idPrefix={area.id} />
      </div>
    </section>
  )}

  <section class="container-page py-16">
    <div class="card-surface flex flex-col items-center gap-5 px-8 py-12 text-center">
      <h2 class="font-display text-2xl text-ink-900 sm:text-3xl">Bu konuda görüşmek ister misiniz?</h2>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={whatsappLink()} target="_blank" rel="noopener noreferrer" class="btn-primary">WhatsApp'tan Yazın</a>
        <a href="/iletisim/" class="btn-secondary">İletişim Formu</a>
      </div>
    </div>
    <p class="mx-auto mt-8 max-w-2xl text-center text-sm leading-relaxed text-ink-700/70">
      Bu içerik genel bilgilendirme amaçlıdır; bireysel değerlendirme ve uzman desteğinin yerine geçmez.
    </p>
  </section>
</BaseLayout>
