---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AreaCard from '../../components/AreaCard.astro';
import { getCollection } from 'astro:content';

const areas = (await getCollection('alanlar')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Danışmanlık Alanlarım"
  description="Sınav kaygısı, ilişki ve çift, bireysel yetişkin, ebeveyn-ergen rehberliği ve kariyer danışmanlığı alanlarında online psikolojik danışmanlık desteği."
>
  <section class="bg-sage-50 py-20">
    <div class="container-page reveal max-w-2xl">
      <p class="eyebrow">Danışmanlık Alanlarım</p>
      <h1 class="mt-4 font-display text-4xl text-ink-900 sm:text-5xl">İhtiyacınıza yakın bir başlangıç noktası</h1>
      <p class="mt-5 text-lg leading-relaxed text-ink-700">
        Aşağıdaki alanlar, online psikolojik danışmanlık kapsamında sunduğum destek konularını
        özetler. Her alanın detay sayfasında süreç, kimler için uygun olduğu ve sık sorulan sorular
        yer alır.
      </p>
    </div>
  </section>

  <section class="container-page py-20">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {areas.map((area, i) => (
        <AreaCard
          href={`/danismanlik-alanlarim/${area.id}/`}
          title={area.data.title}
          summary={area.data.summary}
          index={i + 1}
        />
      ))}
    </div>
  </section>
</BaseLayout>
