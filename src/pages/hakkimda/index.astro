---
import BaseLayout from '../../layouts/BaseLayout.astro';
import OrganicDivider from '../../components/OrganicDivider.astro';
import { whatsappLink } from '../../lib/site';

const credentials = [
  'Lisans, Psikolojik Danışmanlık ve Rehberlik (PDR) — Muğla Sıtkı Koçman Üniversitesi, 2025',
  'Rehber Öğretmen / Psikolojik Danışman — Sınav Hazırlık Kurs Merkezi (Ağustos 2025 – devam ediyor)',
  '300\'den fazla öğrenciyle sınav kaygısı, öğrenci rehberliği ve çalışma süreci yönetimi üzerine birebir çalışma deneyimi',
  '[DÜZENLE — varsa sertifika adı ve yılı]',
];

const approach = [
  {
    title: 'Şeffaflık',
    text: 'Sürecin nasıl ilerleyeceğini en baştan birlikte konuşuruz. Görüşme sıklığı, üzerinde çalışacağımız konular ve neler bekleyebileceğiniz konusunda açık olmaya özen gösteririm. Belirsizlik değil, netlik güven oluşturur.',
  },
  {
    title: 'Gizlilik ve Güven',
    text: 'Görüşmelerde paylaştıklarınız gizlilik ilkesi çerçevesinde korunur. Hiçbir konuyu yargılamadan dinlerim; kendinizi olduğunuz gibi ifade edebileceğiniz, güvenli bir alan oluşturmaya öncelik veririm.',
  },
  {
    title: 'Sizin Yolunuz',
    text: 'Size hazır çözümler dayatmam. Doğru soruları sorarak, kendi gücünüzü ve size uygun yolu birlikte keşfederiz. Süreç sizin hızınızda, sizin ihtiyaçlarınıza göre şekillenir.',
  },
];
---

<BaseLayout
  title="Hakkımda"
  description="Psikolojik Danışman Selcan Sarılmış. Muğla Sıtkı Koçman Üniversitesi PDR mezunu. Sınav kaygısı, öğrenci rehberliği ve kariyer danışmanlığında 300'den fazla öğrenciyle çalışma deneyimi. Online psikolojik danışmanlık."
>
  <section class="bg-sage-50">
    <div class="container-page grid items-center gap-12 py-20 md:grid-cols-[0.9fr_1.1fr]">
      <div class="relative mx-auto aspect-[4/5] w-full max-w-sm md:order-2">
        <div class="absolute inset-0 rounded-organic bg-sky-300/60"></div>
        <img
          src="/images/selcan-sarilmis.jpg"
          alt="Psikolojik Danışman Selcan Sarılmış"
          width="800"
          height="1000"
          loading="eager"
          class="absolute inset-3 h-[calc(100%-1.5rem)] w-[calc(100%-1.5rem)] rounded-organic border border-cream-50/70 object-cover"
        />
      </div>
      <div class="md:order-1">
        <p class="eyebrow">Hakkımda</p>
        <h1 class="mt-4 font-display text-4xl text-ink-900 sm:text-5xl">
          Psikolojik Danışman <span class="name-warm">Selcan Sarılmış</span>
        </h1>
        <p class="mt-6 max-w-md text-lg leading-relaxed text-ink-700">
          Sınav kaygısı, öğrenci rehberliği ve kariyer danışmanlığı üzerine, online olarak
          yargılamadan dinlediğim güvenli bir alanda yanınızdayım.
        </p>
      </div>
    </div>
  </section>
  <OrganicDivider from="#eef1e7" to="#fbf6ec" />

  <!-- BİYOGRAFİ -->
  <section class="container-page py-20">
    <div class="reveal grid gap-10 md:grid-cols-[0.8fr_1.2fr] md:items-start">
      <div>
        <p class="eyebrow">Biyografi</p>
        <h2 class="mt-3 font-display text-3xl text-ink-900 sm:text-4xl">Kim olduğumu kısaca tanıyın</h2>
        <p class="mt-5 max-w-xs text-[15px] leading-relaxed text-ink-700/80">
          Sınav kaygısından öğrenci rehberliğine, her görüşmede yargılamadan dinlemeyi ve
          güvenli bir alan kurmayı önceliklendiriyorum.
        </p>
      </div>
      <div class="max-w-2xl space-y-5 text-[17px] leading-relaxed text-ink-700">
        <p>
          Merhaba, ben Psikolojik Danışman Selcan Sarılmış. Muğla Sıtkı Koçman Üniversitesi
          Psikolojik Danışmanlık ve Rehberlik (PDR) bölümünden 2025 yılında mezun oldum.
          Mezuniyetimin ardından, Ağustos 2025'ten bu yana bir sınav hazırlık kurs merkezinde
          rehber öğretmen olarak görev yapıyorum.
        </p>
        <p>
          Bu süreçte 300'den fazla öğrenci ile birebir çalışma fırsatı buldum. Sınav
          dönemlerinin getirdiği kaygı, motivasyon dalgalanmaları, çalışma düzeni kurma ve
          sınav sürecini yönetme konularında öğrencilere ve ailelerine rehberlik ettim. Bu
          deneyim bana, her öğrencinin kendine özgü bir hikâyesi olduğunu ve doğru rehberlikle
          önündeki engellerin aşılabilir hale geldiğini gösterdi.
        </p>
        <p>
          Danışmanlık anlayışımın temelinde yargılamadan dinlemek, güvenli bir alan oluşturmak
          ve danışanın kendi gücünü fark etmesine eşlik etmek yer alıyor. Görüşmelerimi tamamen
          online olarak, Zoom üzerinden yürütüyorum; böylece nerede olursanız olun, size uygun
          bir ortamda destek alabilirsiniz.
        </p>
        <p>
          Birlikte çalışmaya hazır olduğunuzda, iletişim bölümünden bana ulaşabilirsiniz.
        </p>
      </div>
    </div>
  </section>

  <!-- EĞİTİM / SERTİFİKA -->
  <section class="bg-sage-50 py-20">
    <div class="container-page reveal grid gap-10 md:grid-cols-[0.8fr_1.2fr] md:items-start">
      <p class="eyebrow">Eğitim &amp; Sertifikalar</p>
      <ul class="max-w-2xl space-y-4">
        {credentials.map((item) => (
          <li class="flex gap-3 text-[16px] leading-relaxed text-ink-800">
            <svg class="mt-1 h-5 w-5 shrink-0 text-sage-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <path d="M5 12l4 4L19 6" />
            </svg>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- YAKLAŞIM -->
  <section class="container-page py-20">
    <div class="reveal max-w-xl">
      <p class="eyebrow">Danışmanlık Yaklaşımım</p>
      <h2 class="mt-3 font-display text-3xl text-ink-900 sm:text-4xl">Birlikte çalışırken neye önem veririm</h2>
    </div>
    <div class="mt-12 grid gap-6 sm:grid-cols-3">
      {approach.map((item) => (
        <div class="reveal card-surface p-7">
          <h3 class="font-display text-lg text-ink-900">{item.title}</h3>
          <p class="mt-2 text-[15px] leading-relaxed text-ink-700">{item.text}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- FOTOĞRAF GALERİSİ -->
  <section class="bg-sage-50 py-20">
    <div class="container-page reveal">
      <p class="eyebrow">Galeri</p>
      <h2 class="mt-3 font-display text-3xl text-ink-900 sm:text-4xl">[DÜZENLE] Çalışma alanım</h2>
      <div class="mt-10 grid gap-5 sm:grid-cols-3">
        {[1, 2, 3].map((n) => (
          <div class="flex aspect-square items-center justify-center rounded-2xl border border-sand-300 bg-cream-50 text-center text-sm text-ink-700/60">
            [DÜZENLE] Fotoğraf {n}
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="container-page py-20">
    <div class="reveal card-surface flex flex-col items-center gap-5 px-8 py-12 text-center">
      <h2 class="font-display text-2xl text-ink-900 sm:text-3xl">Birlikte çalışmaya hazır mısınız?</h2>
      <a href={whatsappLink()} target="_blank" rel="noopener noreferrer" class="btn-primary">WhatsApp'tan Yazın</a>
    </div>
  </section>
</BaseLayout>
